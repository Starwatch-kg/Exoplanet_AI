{
  "name": "exoplanet-ai-frontend",
  "version": "2.0.0",
  "description": "Advanced AI-powered exoplanet detection system - Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "format": "prettier --write .",
    "analyze": "npx vite-bundle-analyzer"
  },
  "dependencies": {
    "@sentry/react": "^8.40.0",
    "@sentry/vite-plugin": "^2.22.7",
    "@tanstack/react-query": "^5.59.16",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "i18next": "^23.15.2",
    "lucide-react": "^0.451.0",
    "plotly.js": "^2.35.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.1.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.2",
    "react-hotkeys-hook": "^4.6.1",
    "react-i18next": "^15.0.2",
    "react-intersection-observer": "^9.13.1",
    "react-plotly.js": "^2.6.0",
    "react-query": "npm:@tanstack/react-query@^5.59.16",
    "react-query-devtools": "npm:@tanstack/react-query-devtools@^5.59.16",
    "react-router-dom": "^6.28.0",
    "react-use": "^17.5.1",
    "react-virtualized-auto-sizer": "^1.0.24",
    "react-window": "^1.8.10",
    "react-window-infinite-loader": "^1.0.9",
    "tailwind-merge": "^2.5.3",
    "use-debounce": "^10.0.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.18.6",
    "@types/plotly.js": "^2.12.32",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-bundle-analyzer": "^0.11.0",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-pwa": "^0.20.5",
    "vite-plugin-stylelint": "^5.0.0",
    "workbox-webpack-plugin": "^7.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "exoplanet",
    "ai",
    "nasa",
    "tess",
    "astronomy",
    "space",
    "react",
    "typescript",
    "machine-learning"
  ],
  "author": "ExoplanetAI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/exoplanet-ai"
  },
  "homepage": "https://exoplanet-ai.com",
  "bugs": {
    "url": "https://github.com/your-org/exoplanet-ai/issues"
  }
}
